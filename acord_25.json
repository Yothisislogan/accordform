  "logic": {
    "_comment": "Cross-field rules the renderer/validator must enforce.",
    "insurer_references": "Every *_insurer field (insurer_ref) must reference a letter (A-F) whose insurers.row name is filled. Render as a dropdown of filled insurers; write the chosen LETTER to the InsurerLetterCode field.",
    "optional_blocks": "gl / auto / umbrella / wc are optional. When a block's include toggle is off, skip ALL its pdf_fields (leave blank). At least one coverage block must be included to produce a valid cert.",
    "radio_groups": "Within a group only one option's checkbox may be set to '1'; the rest 'Off'. Groups: gl_form_basis, gl_agg_per, umb_type, umb_form, umb_dedret.",
    "reveals": "gl_agg_per=Other reveals gl_agg_other_desc. wc_excluded=Y should prompt the user to fill Description of Operations.",
    "yn_codes": "yn_code fields write literal 'Y' or 'N' text (not checkbox states).",
    "auto_other_slots": "Vehicle_OtherCoveredAuto* and GeneralLiability_OtherCoverage* / OtherPolicy_* slots exist in the PDF but are intentionally omitted from v1 as 'rare'. Add later if needed."
  }
}
