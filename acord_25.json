{
  "_meta": {
    "acord_number": "25",
    "edition": "2016/03",
    "title": "Certificate of Liability Insurance",
    "template_source": "ACORD_25_fillable.pdf",
    "field_name_prefix": "F[0].P1[0].",
    "total_pdf_fields": 128,
    "checkbox_on_value": "1",
    "checkbox_off_value": "Off",
    "notes": [
      "All pdf_field values below are RELATIVE — prepend field_name_prefix before filling.",
      "These are the verified names dumped from the real PDF via `pdftk dump_data_fields`.",
      "Prep each template once: `pdftk template.pdf output clean.pdf drop_xfa` (strips XFA + owner-pw).",
      "Fill clean.pdf with pypdf update_page_form_field_values(auto_regenerate=False), then `pdftk ... flatten`.",
      "ADDL INSD / SUBR WVD fields are TEXT expecting 'Y' or 'N' (NOT checkboxes)."
    ]
  },

  "insurers": {
    "_comment": "Reference table A-F. User fills these once; coverage blocks reference a letter. UX renders the *_InsurerLetterCode_A fields as a dropdown populated from whichever of these are filled.",
