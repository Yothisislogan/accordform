    "rows": [
      { "letter": "A", "name_pdf_field": "Insurer_FullName_A[0]", "naic_pdf_field": "Insurer_NAICCode_A[0]" },
      { "letter": "B", "name_pdf_field": "Insurer_FullName_B[0]", "naic_pdf_field": "Insurer_NAICCode_B[0]" },
      { "letter": "C", "name_pdf_field": "Insurer_FullName_C[0]", "naic_pdf_field": "Insurer_NAICCode_C[0]" },
      { "letter": "D", "name_pdf_field": "Insurer_FullName_D[0]", "naic_pdf_field": "Insurer_NAICCode_D[0]" },
      { "letter": "E", "name_pdf_field": "Insurer_FullName_E[0]", "naic_pdf_field": "Insurer_NAICCode_E[0]" },
      { "letter": "F", "name_pdf_field": "Insurer_FullName_F[0]", "naic_pdf_field": "Insurer_NAICCode_F[0]" }
    ]
  },

