# WIT Forms — environment template.
# Copy to /etc/wit-forms/witforms.env (chmod 600) in production, or `.env` in dev.
# NOTHING in here that is real/secret belongs in git.

# --- Core ---
SECRET_KEY=change-me-to-a-long-random-string
PORT=8097
FLASK_DEBUG=false
SESSION_COOKIE_SECURE=true

# --- Paths (defaults are fine for /opt/wit-forms) ---
# DATA_DIR=/opt/wit-forms/data
# TEMPLATES_DIR=/opt/wit-forms/templates/acord
PDF_RETENTION_DAYS=30            # TODO(logan): confirm retention window

# --- Google OAuth (domain-restricted) --- TODO(logan): supply
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=https://forms.weinsurethings.com/auth/callback
ALLOWED_DOMAINS=weinsurethings.com
# ALLOWED_EMAILS=contractor@example.com      # optional edge-case allowlist
ADMIN_EMAILS=logan@weinsurethings.com

# --- Email --- TODO(logan): pick transport + supply creds
OWNER_CC_EMAIL=owner@weinsurethings.com      # ALWAYS CC'd, enforced server-side
EMAIL_TRANSPORT=smtp                         # smtp | sendgrid
EMAIL_FROM=forms@weinsurethings.com
EMAIL_FROM_NAME=We Insure Things

# SMTP (if EMAIL_TRANSPORT=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# SendGrid (if EMAIL_TRANSPORT=sendgrid)
SENDGRID_API_KEY=

# --- Tooling ---
PDFTK_BIN=pdftk
